NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
SUPABASE_POOLER_HOST=
